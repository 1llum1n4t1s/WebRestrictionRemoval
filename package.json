{
  "name": "web-restriction-remover",
  "version": "1.0.16",
  "type": "commonjs",
  "description": "Chrome extension to remove copy/paste/right-click/text-selection restrictions on web pages",
  "scripts": {
    "ci:install": "npm ci",
    "generate-icons": "node scripts/generate-icons.js",
    "generate-screenshots": "node webstore/generate-screenshots.js",
    "build": "npm run generate-icons && npm run generate-screenshots"
  },
  "devDependencies": {
    "chrome-webstore-upload-cli": "3.5.0",
    "puppeteer": "^24.42.0",
    "sharp": "^0.34.5"
  },
  "keywords": [
    "chrome-extension",
    "copy-paste",
    "right-click",
    "text-selection",
    "web-restrictions"
  ],
  "author": "",
  "license": "MIT"
}
