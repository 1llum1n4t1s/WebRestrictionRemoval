{
  "manifest_version": 3,
  "name": "WEB制限解除サポート",
  "description": "Webページの制限を解除。コピー・ペースト・右クリック・キーボード・印刷・画像保存・オーバーレイ除去など10機能搭載。",
  "version": "1.0.0",
  "action": {
    "default_icon": {
      "16": "images/icon-16.png",
      "48": "images/icon-48.png",
      "128": "images/icon-128.png"
    },
    "default_title": "WEB制限解除サポート",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "images/icon-16.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  },
  "background": {
    "service_worker": "scripts/background.js"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ]
}
